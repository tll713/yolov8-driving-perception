FLASK_DEBUG=0

# MySQL 数据库配置
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=yolov8_driving

# 用户、检测记录、检测目标和风险日志均使用 MySQL
USER_STORAGE=mysql
USER_TABLE_NAME=用户表

# YOLO 推理配置
YOLO_INFERENCE_MODE=balanced
YOLO_IMAGE_SIZE=640
YOLO_REFINE_IMAGE_SIZE=960
YOLO_REFINE_MIN_SIZE=1280
YOLO_REFINE_CONFIDENCE=0.45
YOLO_DEVICE=
